{
  "name": "where-was-i",
  "displayName": "Where Was I",
  "description": "Resume your coding session exactly where you left off",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "whereWasI",
          "title": "Where Was I",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "whereWasI": [
        {
          "type": "webview",
          "id": "whereWasI.sidebarView",
          "name": "Session"
        }
      ]
    },
    "commands": [
      {
        "command": "where-was-i.saveSession",
        "title": "Where Was I: Save Session"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
