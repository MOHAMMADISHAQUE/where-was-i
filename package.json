{
  "name": "kahan-tha-main",
  "displayName": "Kahan Tha Main",
  "publisher": "mohammadishaque",
  "repository": {
    "type": "git",
    "url": "https://github.com/MOHAMMADISHAQUE/where-was-i"
  },
  "description": "Resume your coding session exactly where you left off",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.124.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kahanThaMain",
          "title": "Kahan Tha Main",
          "icon": "images/icon.svg"
        }
      ]
    },
    "views": {
      "kahanThaMain": [
        {
          "type": "webview",
          "id": "kahanThaMain.sidebarView",
          "name": "Session"
        }
      ]
    },
    "commands": [
      {
        "command": "kahan-tha-main.saveSession",
        "title": "Kahan Tha Main: Save Session"
      }
    ],
    "keybindings": [
      {
        "command": "kahan-tha-main.saveSession",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.124.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "typescript-eslint": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
